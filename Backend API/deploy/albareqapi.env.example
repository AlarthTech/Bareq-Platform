# Copy to /etc/albareqapi/env on the production server.
# Loaded by albareqapi.service via EnvironmentFile=/etc/albareqapi/env
# Restart after changes: sudo systemctl restart albareqapi.service

ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=CleaningHouseDB;User Id=sa;Password=CHANGE_ME;Encrypt=False;TrustServerCertificate=True;MultipleActiveResultSets=True

JwtSettings__SecretKey=CHANGE_ME_MIN_32_CHARACTERS

ASPNETCORE_ENVIRONMENT=Production

# Email (SMTP)
EmailSettings__FromEmail=noreply@example.com
EmailSettings__FromName=Bareq
EmailSettings__SmtpHost=mail.example.com
EmailSettings__SmtpPort=465
EmailSettings__Username=noreply@example.com
EmailSettings__Password=CHANGE_ME
EmailSettings__UseSsl=true
EmailSettings__SecureSocketMode=SslOnConnect

# Customer social login — JWT audience validation (public client IDs)
# Google: validate idToken aud against ALL listed client IDs
SocialAuth__Google__ClientIds__0=106533226272-ohk9d2tf1lvnd9i6rnacffurtichatde.apps.googleusercontent.com
SocialAuth__Google__ClientIds__1=890986624234-31gjrl3sk8opup5j1m4g5euqmmtt4930.apps.googleusercontent.com
# Add Android/iOS client IDs if idToken aud differs from Web Client ID:
# SocialAuth__Google__ClientIds__2=ANDROID_OR_IOS_CLIENT_ID.apps.googleusercontent.com

# Apple: validate idToken aud = bundle ID (issuer https://appleid.apple.com)
SocialAuth__Apple__ClientIds__0=ly.albareq.customerapp

# Facebook: App Secret is server-only — never commit real values to git
SocialAuth__Facebook__AppId=CHANGE_ME
SocialAuth__Facebook__AppSecret=CHANGE_ME
